# ═══════════════════════════════════════
# Audio Cutter Pro — Environment Config
# ═══════════════════════════════════════
# Copy this file to .env and fill in your values.

# Flask
FLASK_SECRET_KEY=change-this-to-a-random-secret-key
FLASK_DEBUG=true
FLASK_PORT=5000

# PostgreSQL (optional — for upload logging)
DB_NAME=audio_db
DB_USER=postgres
DB_PASSWORD=your_postgres_password_here
DB_HOST=localhost
DB_PORT=5432
