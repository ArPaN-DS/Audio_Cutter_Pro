# ─────────────────────────────────────────────
#   Audio Cutter Pro — Environment Configuration
#   Copy this file to .env and fill in values
# ─────────────────────────────────────────────

# Flask secret key — CHANGE THIS to a long random string before deploying!
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=your-very-long-random-secret-key-here

# Server port (default: 5000)
FLASK_PORT=5000

# ─── Optional: PostgreSQL Logging ────────────
# Leave blank to disable upload logging
DB_HOST=localhost
DB_PORT=5432
DB_NAME=audio_cutter_logs
DB_USER=postgres
DB_PASSWORD=
